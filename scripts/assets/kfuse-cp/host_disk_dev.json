{
  "name": "system-group",
  "interval": "1m",
  "rules": [
    {
      "expr": "",
      "for": "0s",
      "labels": {
        "Severity": "Warning"
      },
      "annotations": {
        "Kloudfuse Source": "{{ reReplaceAll pathPrefix \"\" externalURL }}/#/alerts/details/{{ $labels.__alert_rule_uid__ }}?folderTitle={{ reReplaceAll \" \" \"%20\"  $labels.grafana_folder }}{{ range $key, $value := $labels }}&matcher={{ $key }}%3D{{ reReplaceAll \" \" \"%20\" $value }}{{ end }}",
        "alertType": "threshold",
        "defaultZero": "",
        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }}, {{ $labels.host }}: device {{ $labels.device }} is running at high usage for the last 5 minutes",
        "forWindow": "5m",
        "ruleType": "metrics",
        "summary": "Host disk /dev usage is greater than 90 percent"
      },
      "grafana_alert": {
        "id": 217,
        "orgId": 1,
        "title": "Host disk /dev usage is greater than 90 percent",
        "condition": "C",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 300,
              "to": 0
            },
            "datasourceUid": "P09C4D52DEC9B98E6",
            "model": {
              "datasource": {
                "type": "prometheus"
              },
              "expr": "( avg by (org_id, kube_cluster_name, device, host)(system_disk_used{kfuse=\"true\",device=~\"/dev/.+\",kf_node=~\".+\"}) ) / ( avg by (org_id, kube_cluster_name, device, host)(system_disk_total{kfuse=\"true\",device=~\"/dev/.+\"}) )",
              "hide": false,
              "interval": "15s",
              "intervalMs": 15000,
              "maxDataPoints": 43200,
              "range": true,
              "refId": "A"
            }
          },
          {
            "refId": "B",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      0.9
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": [
                      "C"
                    ]
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "A",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "reducer": "min",
              "refId": "B",
              "settings": {
                "mode": "dropNN"
              },
              "type": "reduce"
            }
          },
          {
            "refId": "C",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      0.9
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": [
                      "C"
                    ]
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "B",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "refId": "C",
              "type": "threshold"
            }
          }
        ],
        "updated": "2025-04-26T22:29:26Z",
