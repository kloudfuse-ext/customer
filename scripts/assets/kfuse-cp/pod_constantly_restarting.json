{
  "name": "kubernetes-group",
  "interval": "1m",
  "rules": [
    {
      "expr": "",
      "for": "0s",
      "labels": {
        "Severity": "Warning"
      },
      "annotations": {
        "Kloudfuse Source": "{{ reReplaceAll pathPrefix \"\" externalURL }}/#/alerts/details/{{ $labels.__alert_rule_uid__ }}?folderTitle={{ reReplaceAll \" \" \"%20\"  $labels.grafana_folder }}{{ range $key, $value := $labels }}&matcher={{ $key }}%3D{{ reReplaceAll \" \" \"%20\" $value }}{{ end }}",
        "alertType": "change",
        "defaultZero": "",
        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }}, {{ $labels.kube_namespace }}: {{ $labels.pod_name }} is restarting consistently for the last 10 minutes.",
        "forWindow": "10m",
        "ruleType": "metrics",
        "summary": "Pod is constantly restarting"
      },
      "grafana_alert": {
        "id": 234,
        "orgId": 1,
        "title": "Pod is constantly restarting",
        "condition": "C",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 600,
              "to": 0
            },
            "datasourceUid": "P09C4D52DEC9B98E6",
            "model": {
              "datasource": {
                "type": "prometheus"
              },
              "expr": "sum by (org_id, kube_cluster_name, kube_namespace, pod_name)(kubernetes_containers_restarts{kfuse=\"true\",kf_node=~\".+\"}) - sum by (org_id, kube_cluster_name, kube_namespace, pod_name)(kubernetes_containers_restarts{kfuse=\"true\",kf_node=~\".+\"} offset 5m)",
              "hide": false,
              "interval": "15s",
              "intervalMs": 15000,
              "maxDataPoints": 43200,
              "range": true,
              "refId": "A"
            }
          },
          {
            "refId": "B",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      5
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": []
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "A",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "reducer": "min",
              "refId": "B",
              "settings": {
                "mode": "dropNN"
              },
              "type": "reduce"
            }
          },
          {
            "refId": "C",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      5
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": []
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "$B > 5",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "refId": "C",
              "type": "math"
            }
          }
        ],
        "updated": "2025-04-26T21:05:55Z",
        "intervalSeconds": 60,
        "version": 33,
        "uid": "bb5a52d9-67c5-4095-b1bf-50b86ebf79cd",
        "namespace_uid": "b52d4a03-cd0e-4eea-a199-546a2fc53047",
        "rule_group": "kubernetes-group",
        "no_data_state": "OK",
        "exec_err_state": "KeepLast",
        "is_paused": false
      }
    }
  ]
}