{
  "name": "kloudfuse_alerts_group",
  "interval": "1m",
  "rules": [
    {
      "expr": "",
      "for": "0s",
      "labels": {
        "Severity": "Critical"
      },
      "annotations": {
        "Kloudfuse Source": "{{ reReplaceAll pathPrefix \"\" externalURL }}/#/alerts/details/{{ $labels.__alert_rule_uid__ }}?folderTitle={{ reReplaceAll \" \" \"%20\"  $labels.grafana_folder }}{{ range $key, $value := $labels }}&matcher={{ $key }}%3D{{ reReplaceAll \" \" \"%20\" $value }}{{ end }}",
        "__dashboardUid__": "kfuse-system-detailed-cp",
        "__panelId__": "58",
        "alertType": "threshold",
        "defaultZero": "",
        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }}, {{ $labels.kube_namespace }}: {{ $labels.kube_service }}, {{ $labels.persistentvolumeclaim }} usage is greater than 60 percent for last 10 minutes",
        "forWindow": "10m",
        "ruleType": "metrics",
        "runbook_url": "https://kloudfuse.atlassian.net/wiki/spaces/EN/pages/1412005909/Alert+PV+Usage+xx",
        "summary": "PV Usage (Realtime Server) is greater than 60 percent"
      },
      "grafana_alert": {
        "id": 5772,
        "orgId": 1,
        "title": "PV Usage (Realtime Server) is greater than 60 percent",
        "condition": "C",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 600,
              "to": 0
            },
            "datasourceUid": "P09C4D52DEC9B98E6",
            "model": {
              "datasource": {
                "type": "prometheus"
              },
              "expr": "( avg by (org_id, kube_cluster_name, kube_namespace, kube_service, persistentvolumeclaim)(kubernetes_kubelet_volume_stats_used_bytes{kfuse=\"true\",kube_service=\"pinot-server-realtime\",kf_node=~\".+\"}) )*100/( avg by (org_id, kube_cluster_name, kube_namespace, kube_service, persistentvolumeclaim)(kubernetes_kubelet_volume_stats_capacity_bytes{kfuse=\"true\",kube_service=\"pinot-server-realtime\",kf_node=~\".+\"}) )",
              "hide": false,
              "interval": "15s",
              "intervalMs": 15000,
              "maxDataPoints": 43200,
              "range": true,
              "refId": "A"
            }
          },
          {
            "refId": "B",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      60
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": [
                      "C"
                    ]
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "A",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "reducer": "min",
              "refId": "B",
              "settings": {
                "mode": "dropNN"
              },
              "type": "reduce"
            }
          },
          {
            "refId": "C",
            "queryType": "",
            "relativeTimeRange": {
              "from": 0,
              "to": 0
            },
            "datasourceUid": "-100",
            "model": {
              "conditions": [
                {
                  "evaluator": {
                    "params": [
                      60
                    ],
                    "type": "gt"
                  },
                  "operator": {
                    "type": "and"
                  },
                  "query": {
                    "params": [
                      "C"
                    ]
                  },
                  "reducer": {
                    "params": [],
                    "type": "min"
                  },
                  "type": "query"
                }
              ],
              "datasource": {
                "name": "Expression",
                "type": "__expr__",
                "uid": "__expr__"
              },
              "expression": "B",
              "hide": false,
              "intervalMs": 1000,
              "maxDataPoints": 43200,
              "refId": "C",
              "type": "threshold"
            }
          }
        ],
        "updated": "2025-04-26T22:32:48Z",
