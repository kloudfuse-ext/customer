{
  "name": "kubernetes-group",
  "interval": "1m",
  "rules": [
    {
      "expr": "",
      "for": "0s",
      "labels": {
        "Severity": "Warning"
      },
      "annotations": {
        "Kloudfuse Source": "{{ reReplaceAll pathPrefix \"\" externalURL }}/#/alerts/details/{{ $labels.__alert_rule_uid__ }}?folderTitle={{ reReplaceAll \" \" \"%20\"  $labels.grafana_folder }}{{ range $key, $value := $labels }}&matcher={{ $key }}%3D{{ reReplaceAll \" \" \"%20\" $value }}{{ end }}",
        "alertType": "threshold",
        "defaultZero": "",
        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }}, {{ $labels.kube_namespace }}: {{ $labels.kube_deployment }} ready pods are below 100 percent for the last 15 minutes",
        "forWindow": "15m",
        "ruleType": "metrics",
        "summary": "K8S deployment ready pods are below 100 percent"
      },
      "grafana_alert": {
        "id": 233,
        "orgId": 1,
        "title": "K8S deployment ready pods are below 100 percent",
        "condition": "C",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 900,
              "to": 0
            },
            "datasourceUid": "P09C4D52DEC9B98E6",
            "model": {
              "datasource": {
                "type": "prometheus"
              },
              "expr": "(( avg by (org_id, kube_cluster_name, kube_namespace, kube_deployment)(kubernetes_state_deployment_replicas_desired{kfuse=\"true\"}) )-( avg by (org_id, kube_cluster_name, kube_namespace, kube_deployment)(kubernetes_state_deployment_replicas_available{kfuse=\"true\"}) ))",
              "hide": false,
              "interval": "15s",
              "intervalMs": 15000,
              "maxDataPoints": 43200,
              "range": true,
              "refId": "A"
            }
          },
