{
  "name": "system-group",
  "interval": "1m",
  "rules": [
    {
      "expr": "",
      "for": "0s",
      "labels": {
        "Severity": "Warning"
      },
      "annotations": {
        "Kloudfuse Source": "{{ reReplaceAll pathPrefix \"\" externalURL }}/#/alerts/details/{{ $labels.__alert_rule_uid__ }}?folderTitle={{ reReplaceAll \" \" \"%20\"  $labels.grafana_folder }}{{ range $key, $value := $labels }}&matcher={{ $key }}%3D{{ reReplaceAll \" \" \"%20\" $value }}{{ end }}",
        "alertType": "threshold",
        "defaultZero": "",
        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }} 20% of the nodes in the cluster have not be schedulable for the last 15 minutes.",
        "forWindow": "15m",
        "ruleType": "metrics",
        "summary": "Nodes cannot be scheduled"
