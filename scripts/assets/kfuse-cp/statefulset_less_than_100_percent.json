        "description": "{{ $labels.org_id }}, {{ $labels.kube_cluster_name }}, {{ $labels.kube_namespace }}: The statefulset {{ $labels.kube_stateful_set }} has less than 100 percent of pods in a ready state for the last 15 minutes.",
